{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C++ Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/db_main",
            "setupCommands": [
                {
                "description": "Enable pretty-printing for GDB",
                "text": "-enable-pretty-printing",
                "ignoreFailures": true
                }
            ],
            "args": ["--w"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb"
        }
    ]
}